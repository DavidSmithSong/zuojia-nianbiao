# ── 后端（FastAPI）──────────────────────────────────────────────────────────
# PostgreSQL 连接 URL（asyncpg 会自动替换 postgresql:// 前缀）
DATABASE_URL=postgresql://user:password@localhost:5432/zuojia_nianbiao

# Anthropic API Key（用于 AI 关联引擎）
ANTHROPIC_API_KEY=sk-ant-...

# ── 前端（Next.js）──────────────────────────────────────────────────────────
# 前端代理到后端的地址（next.config.ts 中使用）
# 本地开发时可省略，默认为 http://localhost:8000
BACKEND_URL=http://localhost:8000

# ── 生产部署参考 ─────────────────────────────────────────────────────────────
# Railway（后端）：在项目 Variables 面板设置 DATABASE_URL 和 ANTHROPIC_API_KEY
# Vercel（前端）：在项目 Environment Variables 设置 BACKEND_URL=https://your-api.railway.app
